/*
  secrets.h.example  —  TEMPLATE. Copy this file to "secrets.h" and fill in
  your real values. secrets.h is gitignored — it will never be committed.

  cd firmware/cultivator/sign-on
  cp secrets.h.example secrets.h        (or just copy/paste + rename in your editor)
  then edit secrets.h with your real eduroam login.
*/

#ifndef SECRETS_H
#define SECRETS_H

// ---------------------------------------------------------------------------
// EAP_IDENTITY  —  the "outer" identity sent before the encrypted tunnel is up.
// Most institutions accept (or require) an ANONYMOUS outer identity here for
// privacy — e.g. "anonymous@youruniversity.edu" — while the REAL login goes
// in EAP_USERNAME below, inside the encrypted tunnel. If your school's docs
// don't mention an anonymous identity, just use the same value as EAP_USERNAME.
// ---------------------------------------------------------------------------
#define EAP_IDENTITY   "anonymous@youruniversity.edu"

// Your real eduroam login (often your school email / Microsoft account UPN).
#define EAP_USERNAME   "netid@youruniversity.edu"

// The passkey/password for the Microsoft account above.
#define EAP_PASSWORD   "your-passkey-here"

#endif  // SECRETS_H
